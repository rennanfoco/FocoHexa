# Servidor
PORT=3000
NODE_ENV=development

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx

# Modelo de geracao de imagem — troque o valor abaixo para mudar o modelo
# ─────────────────────────────────────────────────────────────────
# openai/gpt-5-image-mini                  ~$0.15-0.25/img  (recomendado)
# openai/gpt-5.4-image-2                   ~$1.00/img       (premium)
# google/gemini-2.5-flash-image            ~$0.05-0.10/img  (Nano Banana)
# google/gemini-3.1-flash-image-preview    ~$0.05-0.10/img  (Nano Banana 2)
# ─────────────────────────────────────────────────────────────────
IMAGE_MODEL=openai/gpt-5-image-mini

# CORS
FRONTEND_URL=http://localhost:5173